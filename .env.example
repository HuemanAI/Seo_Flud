# ── COPY THIS TO .env.local AND FILL IN ──────────────────────────────

# Anthropic - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Database - Postgres (use Neon.tech free tier)
DATABASE_URL=postgresql://user:password@host/seoflud

# NextAuth - run: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe - get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs - create in Stripe dashboard
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# Email - get from resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=hello@seoflud.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SEOflud
